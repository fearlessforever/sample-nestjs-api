# port selected for running this application , default 3000
PORT=
#optional if dont want to run this app with any database module / feature
IS_USE_DB=false

DB_USER=postgres
DB_PASS=
DB_HOST=localhost
DB_PORT=5432
DB_NAME=my_app_db

DATABASE_URL=postgres://$DB_USER:$DB_PASS@$DB_HOST:$DB_PORT/$DB_NAME

#optional if dont want to run this app with any log forward to file in ./logs/YYYY-MM-DD-debug.log
IS_FORWARD_LOG_TO_FILE=false

#Cache Manager , default using app memory , optional using redis
IS_USE_REDIS=false
REDIS_HOST=
REDIS_PORT=
REDIS_PASSWD=
# default redis db = 0
REDIS_DB=


#Activate SOCKET Feature
IS_ACTIVATE_SOCKET=false

#Queue Feature, this need redis connection, can be them same as Cache Manager or a bit different configurations
IS_USE_REDIS_AS_QUEUE=false
QUEUE_REDIS_HOST=
QUEUE_REDIS_PORT=
QUEUE_REDIS_PASSWD=
# default redis db = 0
QUEUE_REDIS_DB=

#Send Email feature , require active queue feature
MAIL_SMTP_HOSTNAME=                  #smtp.gmail.com
MAIL_SMTP_PORT=                      #587 non secure or 465 secure
MAIL_SECURE=                         #true / false
MAIL_AUTH_USERNAME=                  #username or email
MAIL_AUTH_PASS=                      #password app
MAIL_IS_SEND_EMAIL_COPY=             #true / false , everytime sending email , send a copy as BCC to your AUTH_USERNAME email for debugging is sent or not